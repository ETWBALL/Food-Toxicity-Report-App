# App
NEXT_PUBLIC_APP_NAME=SafeScan
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-random-secret

# Optional: server-to-server auth for POST/PUT /api/products (Bearer token).
# If unset, catalog writes require a logged-in session instead.
INTERNAL_API_KEY=

# Database (Neon/Postgres)
POSTGRES_URL=postgres://user:password@host/dbname
DATABASE_URL=postgres://user:password@host/dbname

# AI + analysis backend (legacy / unused by Next analysis route unless you wire them)
OPENAI_API_KEY=
WATSONX_API_KEY=
ANALYSIS_BACKEND=next
FASTAPI_BASE_URL=http://localhost:8000

# External product sources (legacy; OFF v2 URL is hardcoded in code)
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org/api/v0

# POST /api/reports — NewsAPI (e.g. q=product+recall)
NEWS_API_KEY=

# Barcode resolution: UPC Database first, then RapidAPI fallback (see lib/integrations/rapid-barcode.ts)
UPC_API_KEY=
RAPID_API_KEY=
# RapidAPI host for your subscribed barcode product API (default: barcodes1.p.rapidapi.com)
RAPID_API_BARCODE_HOST=
# Optional path template with {barcode}, e.g. /?bin={barcode}
RAPID_API_BARCODE_PATH=

# openFDA (recalls + FAERS + food events) — https://open.fda.gov/apis/
FDA_OPENFDA_API_KEY=

# Nutrition (Edamam optional; API Ninjas https://api-ninjas.com/api/nutrition )
EDAMAM_APP_ID=
EDAMAM_APP_KEY=
API_NINJAS_KEY=

# DailyMed + RxNorm are called from code without keys (NIH public APIs).

# Re-fetch barcode-derived product metadata after N days (UPC DB / Rapid / OFF)
PRODUCT_CACHE_TTL_DAYS=30

# Featherless AI — OpenAI-compatible Chat Completions (https://featherless.ai/docs/api-overview-and-common-options)
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# Default: Llama 3.1 70B Instruct on Featherless (override if your account lists a different slug)
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
