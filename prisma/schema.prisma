generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id            Int              @id @default(autoincrement())
  publicId      String           @unique @map("public_id")
  name          String
  email         String           @unique
  passwordHash  String           @map("password_hash")
  country       String?
  avatarUrl     String?          @map("avatar_url")
  createdAt     DateTime         @default(now()) @map("created_at")
  age           Int?
  deletedAt     DateTime?        @map("deleted_at")
  /// Increment to invalidate all outstanding JWT refresh/access families (logout).
  tokenVersion  Int              @default(0) @map("token_version")
  notifications Notification[]
  safetyReports SafetyReport[]
  scanHistory   ScanHistory[]
  allergies     UserAllergy[]
  conditions    UserCondition[]
  medications   UserMedication[]

  @@map("users")
}

model Product {
  id               Int     @id @default(autoincrement())
  name             String
  description      String?
  servingSize      String? @map("serving_size")
  countryOfOrigin  String? @map("country_of_origin")
  brand            String? // who makes it
  manufacturer     String? // who manufactures it
  /// DB column is `barcode`; UNIQUE index is `products_barcode_key` — reused so no destructive index swap.
  barcodeNumber    String? @unique(map: "products_barcode_key") @map("barcode")
  ingredientList   String? @map("ingredients")
  /// DB column is JSONB; we read/write as a stringified JSON in app code (see app/api/products/route.ts).
  nutritionalInfo  String? @map("nutritional_info")
  imageUrl         String? @map("image_url")
  type             String? // Drugs, food, supplement
  /// FDA-flagged product (existing column on DB; previously absent from schema).
  fda              Boolean @default(false)
  /// Last successful external barcode→product resolution (Go-UPC, Barcode Lookup, OFF, etc.)
  lastExternalResolutionAt DateTime? @map("last_external_resolution_at")
  /// e.g. upc-database | rapid-barcode | openfoodfacts | merged
  externalResolutionSource String?   @map("external_resolution_source")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  scanHistory      ScanHistory[]
  recalls          Recall[]
  safetyReports    SafetyReport[]
  notifications    Notification[]

  @@map("products")
}

model ScanHistory {
  id            Int            @id @default(autoincrement())
  userId        Int            @map("user_id")
  productId     Int?           @map("product_id")
  barcode       String?
  score         Int?
  verdict       String?
  scannedAt     DateTime       @default(now()) @map("scanned_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  safetyReports SafetyReport[]
  product       Product?       @relation(fields: [productId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("scan_history")
}

model Recall {
  id                   Int            @id @default(autoincrement())
  productId            Int?           @map("product_id")
  barcode              String?
  recallReason         String?        @map("recall_reason")
  recallDescription    String?        @map("recall_description")
  severityLevel        String?        @map("severity_level")
  recallDate           DateTime?      @map("recall_date")
  recallExpiryDate     DateTime?      @map("recall_expiry_date")
  active               Boolean        @default(true)
  source               String?        @default("FDA")
  issuingAuthority     String?        @map("issuing_authority")
  officialRecallUrl    String?        @map("official_recall_url")
  recallNumber         String?        @map("recall_number")
  affectedBatchNumbers String?        @map("affected_batch_numbers")
  affectedUpcCodes     String?        @map("affected_upc_codes")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  notifications        Notification[]
  product              Product?       @relation(fields: [productId], references: [id])

  @@map("recalls")
}

model UserMedication {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  name           String?
  medicationName String?
  dosage         String?
  frequency      String?
  addedAt        DateTime @default(now()) @map("added_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_medications")
}

model UserAllergy {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String?
  allergen  String?
  severity  String?
  addedAt   DateTime @default(now()) @map("added_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_allergies")
}

model UserCondition {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  name          String?
  conditionName String?
  diagnosedAt   DateTime? @map("diagnosed_at")
  addedAt       DateTime  @default(now()) @map("added_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_conditions")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String
  message   String
  productId Int?     @map("product_id")
  recallId  Int?     @map("recall_id")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product? @relation(fields: [productId], references: [id])
  recall    Recall?  @relation(fields: [recallId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SafetyReport {
  id                   Int          @id @default(autoincrement())
  scanId               Int?         @map("scan_id")
  userId               Int          @map("user_id")
  productId            Int?         @map("product_id")
  score                Int?         @map("score")
  verdict              String?      @map("verdict")
  overallScore         Int?         @map("overall_score")
  reportDate           DateTime     @default(now()) @map("report_date")
  allergenScore        Int?
  toxicityScore        Int?
  recallScore          Int?
  drugInteractionScore Int?
  adverseEventScore    Int?
  knownReactions       String?
  potentialHarms       Json?        @map("potential_harms")
  allergenFlags        String?
  drugFlags            String?
  toxicityFlags        String?
  severityLevel        String?
  isPersonalized       Boolean      @default(false)
  fdaReportCount       Int?
  fdaReactionSummary   String?
  nutritionalScore     Int?
  calories             Int?
  sugarLevel           String?
  sodiumLevel          String?
  saturatedFatLevel    String?
  proteinLevel         String?
  fiberLevel           String?
  nutritionalFlags     String?
  nutritionalSummary   String?
  dailyValueWarnings   String?
  conditionFlags       String?
  aiAnalysisSummary    String?
  summary              String?
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  product              Product?     @relation(fields: [productId], references: [id])
  scan                 ScanHistory? @relation(fields: [scanId], references: [id])
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reports")
}
